{
    "name": "aryeo/eloquent-state-machines",
    "description": "A state machine package for Eloquent.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Support\\": "src/Support/",
            "Tooling\\": "src/Tooling/"
        },
        "exclude-from-classmap": [
            "*Test.php",
            "*TestCases.php",
            "/tests/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Justin Seliga",
            "email": "justinsel@zillowgroup.com"
        }
    ],
    "minimum-stability": "stable",
    "repositories": {
        "tooling-laravel": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/tooling-laravel"
        },
        "actions": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/actions"
        }
    },
    "require": {
        "php": "^8.4",
        "aryeo/actions": "0.0.13",
        "laravel/framework": "12.x",
        "laravel/prompts": "^0.3.7",
        "symfony/console": "^7.3",
        "symfony/finder": "^7.3",
        "phpstan/phpstan": "^2.1",
        "nikic/php-parser": "^5.7",
        "rector/rector": "^2.3",
        "phpstan/phpdoc-parser": "^2.3"
    },
    "require-dev": {
        "orchestra/testbench": "^10.6",
        "phpunit/phpunit": "^12.4.1",
        "pestphp/pest": "^4.1",
        "aryeo/tooling-laravel": "0.0.36",
        "nesbot/carbon": "^3.10",
        "orchestra/testbench-core": "^10.7",
        "symplify/rule-doc-generator-contracts": "^11.2"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "aryeo/tooling-laravel": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Support\\Database\\Eloquent\\StateMachines\\Provider"
            ]
        },
        "tooling": {
            "rector": {
                "rules": "tooling/rector/rules.php",
                "configured_rules": "tooling/rector/configured-rules.php",
                "skip": "tooling/rector/skip.php"
            },
            "phpstan": "tooling/phpstan/phpstan.neon"
        }
    }
}
